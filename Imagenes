        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Definir las raíces del polinomio\n",
        "roots = [1+1j, 1-1j, -1+1j, -1-1j]\n",
        "\n",
        "# Definir el polinomio a partir de sus raíces\n",
        "p = np.poly(roots)\n",
        "\n",
        "# Definir el rango de valores de la parte real e imaginaria\n",
        "x = np.linspace(-2, 2, 1000)\n",
        "y = np.linspace(-2, 2, 1000)\n",
        "\n",
        "# Crear una malla de valores complejos a partir de los vectores x e y\n",
        "X, Y = np.meshgrid(x, y)\n",
        "Z = X + Y*1j\n",
        "\n",
        "# Calcular la magnitud del polinomio en la malla de valores complejos\n",
        "mag_p = np.abs(np.polyval(p, Z))\n",
        "\n",
        "# Graficar la magnitud del polinomio en una escala de colores\n",
        "plt.imshow(mag_p, cmap='inferno', extent=[-2, 2, -2, 2], vmin=0.1)\n",
        "plt.colorbar()\n",
        "\n",
        "# Ajustar los límites de los ejes\n",
        "plt.xlim([-2, 2])\n",
        "plt.ylim([-2, 2])\n",
        "\n",
        "# Agregar las raíces del polinomio como puntos en la gráfica\n",
        "plt.scatter(roots.real, roots.imag, color='white')\n",
        "\n",
        "# Mostrar la gráfica\n",
        "plt.show()\n"
      ],
