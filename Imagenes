        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "def semicircle(r, resolution):\n",
        "    x = np.linspace(-r, r, resolution)\n",
        "    y = np.linspace(-r, r, resolution)\n",
        "    xx, yy = np.meshgrid(x, y, sparse=True)\n",
        "    z = xx**2 + yy**2 <= r**2\n",
        "    z &= yy >= 0  # seleccionar solo puntos en el semicírculo superior\n",
        "    return z\n",
        "\n",
        "\n",
        "z = semicircle(1.5, 200)\n",
        "plt.imshow(z, cmap='gray', extent=[-1.5, 1.5, -1.5, 1.5])\n",
        "plt.show()\n"
